# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ordinexa_proposals?schema=public"

# Application URL
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# AI Generation Provider
# Set GEMINI_API_KEY to enable Gemini provider for proposal generation
# If not set, the mock provider will be used for local development
GEMINI_API_KEY=""

# Optional: Google API Key for additional services
GOOGLE_API_KEY=""

# AI Provider Configuration
AI_PROVIDER="gemini"
AI_USE_MOCK_FALLBACK="true"
AI_MODEL="gemini-3.1-flash-lite-preview"
