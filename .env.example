# Database (required for production, optional for demo)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ordinexa_proposals?schema=public"

# Application URL (required for production)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# AI Generation Provider (optional for demo)
# Set GEMINI_API_KEY to enable Gemini AI for proposal generation
# If not set, the app will use the mock provider for demo purposes
# Get your key from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=""

# Optional: Google API Key for additional services
GOOGLE_API_KEY=""

# AI Provider Configuration (auto-managed, can be left as-is)
AI_PROVIDER="gemini"
AI_USE_MOCK_FALLBACK="true"
AI_MODEL="gemini-3.1-flash-lite-preview"
