{
  "name": "ordinexa-proposals",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test:unit": "node --import tsx --test tests/unit/**/*.test.ts",
    "test:e2e": "playwright test",
    "test": "pnpm test:unit && pnpm test:e2e",
    "test:all": "pnpm typecheck && pnpm lint && pnpm test:unit && pnpm test:e2e && pnpm build",
    "validate": "pnpm typecheck && pnpm lint && pnpm test:unit && pnpm test:e2e && pnpm build",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@prisma/client": "^7.6.0",
    "clsx": "^2.1.1",
    "lucide-react": "^0.468.0",
    "next": "16.2.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.1",
    "@prisma/adapter-pg": "^7.0.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "dotenv": "^17.2.3",
    "pg": "^8.16.3",
    "prisma": "^7.0.0",
    "tailwindcss": "^4",
    "tsx": "^4.20.6",
    "typescript": "^5"
  }
}